<ui:FluentWindow
    x:Class="EfMigrationManager.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:EfMigrationManager.App.Behaviors"
    xmlns:conv="clr-namespace:EfMigrationManager.App.Converters"
    xmlns:vm="clr-namespace:EfMigrationManager.App.ViewModels"
    xmlns:models="clr-namespace:EfMigrationManager.Core.Models;assembly=EfMigrationManager.Core"
    Title="EF Migration Manager"
    Width="1280" Height="800"
    MinWidth="900" MinHeight="550"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    Loaded="Window_Loaded"
    Closing="Window_Closing"
    SourceInitialized="Window_SourceInitialized">

    <ui:FluentWindow.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisInverse" Invert="True"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:MigrationStatusToIconConverter x:Key="StatusToIcon"/>
        <conv:ColorHintToBrushConverter x:Key="ColorHintToBrush"/>
        <conv:InverseBoolConverter x:Key="InvertBool"/>
        <conv:NotificationSeverityConverter x:Key="SevConv"/>
        <conv:NotNullToBoolConverter x:Key="NotNullBool"/>
        <conv:PathToShortDisplayConverter x:Key="ShortPath"/>

        <SolidColorBrush x:Key="AppliedBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="PendingBrush" Color="#FFC107"/>
    </ui:FluentWindow.Resources>

    <ui:FluentWindow.InputBindings>
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding SolutionPanel.BrowseCommand}"/>
        <KeyBinding Key="F5" Command="{Binding MigrationPanel.RefreshContextsCommand}"/>
        <KeyBinding Modifiers="Control" Key="R" Command="{Binding MigrationPanel.RefreshMigrationsCommand}"/>
        <KeyBinding Modifiers="Control" Key="L" Command="{Binding Terminal.ClearCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding MigrationPanel.CancelExecutionCommand}"/>
    </ui:FluentWindow.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="EF Migration Manager"
                     ShowMinimize="True"
                     ShowMaximize="True"
                     ShowClose="True">
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Text="Light" VerticalAlignment="Center" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,6,0"/>
                    <ui:ToggleSwitch x:Name="ThemeToggle" Checked="ThemeToggle_Toggled" Unchecked="ThemeToggle_Toggled"/>
                    <TextBlock Text="Dark" VerticalAlignment="Center" FontSize="11"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="6,0,0,0"/>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <ui:InfoBar Grid.Row="1"
                    x:Name="StartupInfoBar"
                    Margin="8,8,8,0"
                    IsClosable="True"
                    IsOpen="False"
                    Severity="Warning"/>

        <ui:InfoBar Grid.Row="2"
                    Margin="8,8,8,0"
                    IsClosable="True"
                    Title="{Binding MigrationPanel.Notification.Title}"
                    Message="{Binding MigrationPanel.Notification.Message}"
                    Severity="{Binding MigrationPanel.Notification.Severity, Converter={StaticResource SevConv}, FallbackValue=Informational}"
                    IsOpen="{Binding MigrationPanel.Notification, Converter={StaticResource NotNullBool}, FallbackValue=False}"
                    Visibility="{Binding MigrationPanel.Notification, Converter={StaticResource NullToVis}}"/>

        <Grid Grid.Row="3" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="280"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="440" MinWidth="360"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"   MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- Column 0: Solution Panel -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                    CornerRadius="6" Padding="10">
                <Grid DataContext="{Binding SolutionPanel}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Solution" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                    <ui:Button Grid.Row="1"
                               Content="Open Solution..."
                               Icon="{ui:SymbolIcon FolderOpen24}"
                               Command="{Binding BrowseCommand}"
                               HorizontalAlignment="Stretch"
                               Appearance="Primary"
                               Margin="0,0,0,8"/>

                    <ui:ProgressRing Grid.Row="2"
                                     IsIndeterminate="True"
                                     Width="24" Height="24"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                     HorizontalAlignment="Left" Margin="0,0,0,8"/>

                    <ui:InfoBar Grid.Row="3"
                                IsOpen="{Binding ErrorMessage, Converter={StaticResource NullToVis}, ConverterParameter=open}"
                                Severity="Error"
                                Title="Error"
                                Message="{Binding ErrorMessage}"
                                Margin="0,0,0,8"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}"/>

                    <Expander Grid.Row="4" Header="Recent Solutions" IsExpanded="True" Margin="0,0,0,8">
                        <ListBox ItemsSource="{Binding RecentSolutions}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 MaxHeight="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource ShortPath}}"
                                               ToolTip="{Binding}"
                                               TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <EventSetter Event="MouseDoubleClick" Handler="RecentSolution_DoubleClick"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Expander>

                    <GroupBox Grid.Row="5" Header="Solution Explorer" Margin="0,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <CheckBox Grid.Row="0"
                                      Content="Show all projects"
                                      IsChecked="{Binding ShowAllProjects, Mode=TwoWay}"
                                      Margin="4,2,4,6"
                                      FontSize="11"/>

                            <TreeView Grid.Row="1"
                                      x:Name="SolutionTreeView"
                                      ItemsSource="{Binding DataContext.SolutionTree.Roots, RelativeSource={RelativeSource AncestorType=Window}}"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                      Padding="0,0,0,28">
                                <TreeView.Resources>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Padding" Value="0,0,0,28"/>
                                    </Style>
                                    <ContextMenu x:Key="ProjectMenu">
                                        <MenuItem Header="Add Migration..."         Click="Tree_AddMigration_Click"/>
                                        <MenuItem Header="Update to Latest"         Click="Tree_UpdateLatest_Click"/>
                                        <MenuItem Header="Update to..."             Click="Tree_UpdateTo_Click"/>
                                        <MenuItem Header="Remove Last Migration"    Click="Tree_RemoveMigration_Click"/>
                                        <MenuItem Header="Generate Script..."       Click="Tree_GenerateScript_Click"/>
                                        <MenuItem Header="Drop Database"            Click="Tree_DropDatabase_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Set as Migrations Project" Click="Tree_SetAsMigrations_Click"/>
                                        <MenuItem Header="Set as Startup Project"    Click="Tree_SetAsStartup_Click"/>
                                    </ContextMenu>
                                </TreeView.Resources>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="True"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate DataType="{x:Type vm:SolutionNode}" ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Tag="{Binding}" MouseRightButtonDown="Tree_Node_RightClick"
                                                    ContextMenu="{StaticResource ProjectMenu}">
                                            <TextBlock Text="{Binding Icon}" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=Foreground}"/>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=Foreground}"/>
                                            <Border Background="#1565C0"
                                                    CornerRadius="3"
                                                    Padding="4,1"
                                                    Margin="6,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding Badge, Converter={StaticResource NullToVis}}">
                                                <TextBlock Text="{Binding Badge}" Foreground="White" FontSize="10"/>
                                            </Border>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </Grid>
                    </GroupBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- Column 2: Migration Panel -->
            <Border Grid.Column="2"
                    Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}"
                    CornerRadius="6" Padding="10">
                <Grid DataContext="{Binding MigrationPanel}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Migrations" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                    <GroupBox Grid.Row="1" Header="Configuration" Margin="0,0,0,8">
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Startup Project:" VerticalAlignment="Center" Margin="0,4"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                      ItemsSource="{Binding StartupProjects}"
                                      SelectedItem="{Binding SelectedStartupProject}"
                                      DisplayMemberPath="Name"
                                      Margin="0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Migrations Project:" VerticalAlignment="Center" Margin="0,4"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                      ItemsSource="{Binding MigrationProjects}"
                                      SelectedItem="{Binding SelectedMigrationsProject}"
                                      DisplayMemberPath="Name"
                                      Margin="0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="DbContext:" VerticalAlignment="Center" Margin="0,4"/>
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      ItemsSource="{Binding Contexts}"
                                      SelectedItem="{Binding SelectedContext}"
                                      DisplayMemberPath="ShortName"
                                      Margin="0,4"/>
                            <ui:Button Grid.Row="2" Grid.Column="2"
                                       Icon="{ui:SymbolIcon ArrowClockwise24}"
                                       Command="{Binding RefreshContextsCommand}"
                                       ToolTip="Discover DbContexts"
                                       Margin="6,4,0,4"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Row="2" Header="Actions" Margin="0,0,0,8">
                        <WrapPanel Margin="4">
                            <ui:Button Content="Add Migration"       Icon="{ui:SymbolIcon Add24}"           Click="AddMigration_Click"   Margin="0,0,6,6"/>
                            <ui:Button Content="Remove Last"         Icon="{ui:SymbolIcon Subtract24}"      Click="RemoveMigration_Click" Margin="0,0,6,6"/>
                            <ui:Button Content="Update to Latest"    Icon="{ui:SymbolIcon ArrowUp24}"       Command="{Binding UpdateDatabaseCommand}" Margin="0,0,6,6"/>
                            <ui:Button Content="Update to..."        Icon="{ui:SymbolIcon Target24}"        Click="UpdateTo_Click"        Margin="0,0,6,6"/>
                            <ui:Button Content="Generate Script"     Icon="{ui:SymbolIcon Document24}"      Click="GenerateScript_Click"  Margin="0,0,6,6"/>
                            <ui:Button Content="Drop Database"       Icon="{ui:SymbolIcon Delete24}"        Appearance="Danger" Click="DropDatabase_Click" Margin="0,0,6,6"/>
                            <ui:Button Content="Cancel"              Icon="{ui:SymbolIcon Stop24}"          Command="{Binding CancelExecutionCommand}" Appearance="Caution"
                                       Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVis}}"
                                       Margin="0,0,6,6"/>
                        </WrapPanel>
                    </GroupBox>

                    <GroupBox Grid.Row="3" Header="Migration History">
                        <Grid>
                            <ui:ProgressRing IsIndeterminate="True" Width="24" Height="24"
                                             HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8"
                                             Visibility="{Binding IsLoadingMigrations, Converter={StaticResource BoolToVis}}"/>

                            <ListView x:Name="MigrationsListView"
                                      ItemsSource="{Binding Migrations}"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      BorderThickness="0"
                                      Background="Transparent"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <ListView.Resources>
                                    <Style TargetType="{x:Type GridViewColumnHeader}">
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <Setter Property="Background" Value="{DynamicResource SolidBackgroundFillColorBaseBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                    </Style>
                                </ListView.Resources>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="4,2"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsSelected" Value="True"/>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                </MultiTrigger.Conditions>
                                                <Setter Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                            </MultiTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Update database to this migration"
                                                  Click="UpdateToMigration_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Copy migration name"
                                                  Click="CopyMigrationName_Click"/>
                                        <MenuItem Header="Copy migration ID"
                                                  Click="CopyMigrationId_Click"/>
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="" Width="32">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate DataType="{x:Type models:MigrationEntry}">
                                                    <TextBlock Text="{Binding StatusIcon}" FontSize="14" HorizontalAlignment="Center"
                                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Name" Width="180">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate DataType="{x:Type models:MigrationEntry}">
                                                    <TextBlock Text="{Binding SafeName}"
                                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="ID" Width="170">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate DataType="{x:Type models:MigrationEntry}">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"
                                                               FontSize="11"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="Timestamp" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate DataType="{x:Type models:MigrationEntry}">
                                                    <TextBlock Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}">
                                                        <TextBlock.Text>
                                                            <Binding Path="Timestamp" StringFormat="{}{0:yyyy-MM-dd HH:mm}"/>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Grid>
                    </GroupBox>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Center"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- Column 4: Terminal -->
            <Border Grid.Column="4"
                    Background="#1E1E1E"
                    CornerRadius="6" Padding="8">
                <Grid DataContext="{Binding Terminal}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Terminal" FontWeight="Bold" FontSize="14" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ui:Button Content="Clear"    Command="{Binding ClearCommand}"     Margin="0,0,4,0"/>
                        <ui:Button Content="Copy All" Command="{Binding CopyAllCommand}"   Margin="0,0,4,0"/>
                        <ui:Button Content="Open in Terminal" Command="{Binding OpenInTerminalCommand}" Margin="0,0,4,0"/>
                        <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20" Margin="6,0,0,0"
                                         Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#0F0F0F" CornerRadius="4">
                        <ScrollViewer x:Name="TerminalScroller" VerticalScrollBarVisibility="Auto" Padding="8">
                            <b:Interaction.Behaviors>
                                <behaviors:AutoScrollBehavior/>
                            </b:Interaction.Behaviors>
                            <ItemsControl ItemsSource="{Binding Lines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:TerminalLine}">
                                        <TextBlock Text="{Binding Text}"
                                                   Foreground="{Binding ColorHint, Converter={StaticResource ColorHintToBrush}}"
                                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Margin="0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="4" Padding="8,2">
            <StatusBarItem>
                <TextBlock Text="{Binding MigrationPanel.StatusMessage}"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</ui:FluentWindow>
