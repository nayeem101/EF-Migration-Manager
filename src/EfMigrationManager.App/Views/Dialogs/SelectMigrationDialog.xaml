<ui:FluentWindow
    x:Class="EfMigrationManager.App.Views.Dialogs.SelectMigrationDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:models="clr-namespace:EfMigrationManager.Core.Models;assembly=EfMigrationManager.Core"
    Title="Select Migration"
    Width="560" Height="460"
    WindowStartupLocation="CenterOwner"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Select Migration"/>

        <ListBox Grid.Row="1"
                 x:Name="MigrationList"
                 Margin="16,8"
                 MouseDoubleClick="MigrationList_DoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:MigrationEntry}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding StatusIcon}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Name}" FontFamily="Cascadia Code, Consolas"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,0,16,16">
            <ui:Button Content="Cancel" IsCancel="True" Click="Cancel_Click" Margin="0,0,8,0"/>
            <ui:Button Content="OK" Appearance="Primary" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
